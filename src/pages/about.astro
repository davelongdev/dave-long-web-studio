---
// component import
import MainLayout from "../layouts/MainLayout.astro";
import { Picture } from "astro:assets";
import headshot from "../assets/headshot.jpg";
---

<MainLayout title="About" description="About Page">
  <section>
    <div class="flex flex-col">
      <h1 class="text-center text-4xl my-10">About</h1>
      <Picture
        src={headshot}
        alt="Headshot"
        class="mx-auto mb-14 mb-10 rounded-md"
        width={headshot.width / 3}
        densities={[1.5, 2]}
        formats={["webp", "avif", "jpg"]}
      />
      <p class="text-xl px-10 pb-5 max-w-3xl mx-auto">
        Lorem ipsum, dolor sit amet consectetur adipisicing elit. Ea cupiditate
        maiores assumenda est, facilis, doloremque eius consequatur illum iusto
        a officiis esse velit veniam expedita labore itaque sit facere
        reprehenderit? Vitae repudiandae quod est? Nemo quia cupiditate atque
        totam deleniti.
      </p>
      <a
        class="py-1.5 px-2 m-10 border rounded-md bg-slate-400 self-center"
        href="mailto:davelongdev@gmail.com"
        >Contact Me
      <a />
    </div>
  </section>
</MainLayout>
