---
import { Icon } from "astro-icon/components"
import Social from "./Social.astro";
---

<footer class="mt-5">
  <hr class="mb-5">
  <div class="text-lg my-8">
    <div class="flex justify-center my-1">
      Copyright &copy  <span class="mr-2 ml-1" id="copyright"></span> | All rights reserved 
    </div>
    <div class="flex justify-center mb-5">
      <a class="flex justify-center" href="/rss.xml">
        Subscribe to RSS
          <Icon class="ml-2" name="tabler:rss" width='20' height='20' />
      </a>
    </div>
  </div>
  <div class="text-center mb-10">
    <Social platform="twitter" username="davelongdev_" />
    <Social platform="github" username="davelongdev" />
    <a  
      class="py-1.5 px-2 mx-2 border rounded-md bg-slate-400"
      href="mailto:davelongdev@gmail.com"
    >
    email
    </a>
  </div>
<footer />

<script>
document.querySelector("#copyright").textContent = new Date().getFullYear().toString()
</script>

